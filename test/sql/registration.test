# The parser fixtures are generated by Rust and shell integration tests. This
# sqllogictest verifies that a Community Extension build loads and registers
# the complete SQL surface without shipping real telemetry files.

require motorsport_telemetry

query I
SELECT count(*)
FROM duckdb_functions()
WHERE function_name IN (
  'telemetry_metadata',
  'telemetry_samples',
  'read_telemetry',
  'read_cosworth',
  'read_motec',
  'read_vbo'
);
----
6
